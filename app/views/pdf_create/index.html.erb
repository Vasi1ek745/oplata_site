<% content_for :title, "PDF Create" %>

<div class="w-full mt-0 pt-0 px-4 sm:px-0">
  <div class="mb-6">
    <h1 class="font-bold text-2xl sm:text-3xl mb-2">Создание PDF</h1>
    <p class="text-gray-500 text-sm">Выберите экзамен и тип формируемого документа</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <%# Математика ЕГЭ %>
    <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-all duration-300 border border-gray-200 overflow-hidden">
      <div class="bg-gray-50 border-b border-gray-200 px-6 py-4 flex items-center gap-3">
        <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
        <h2 class="text-xl font-bold text-gray-700">Математика ЕГЭ профиль</h2>
      </div>
      <div class="p-6">
        <div class="flex flex-col gap-3">
          <%= form_tag pdf_create_generate_path, method: :post, data: { turbo: false }, target: "_blank" do %>
            <%= hidden_field_tag :exam, "math_ege" %>
            <%= hidden_field_tag :part, "first_part" %>
            <button type="submit" class="w-full px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition font-medium text-sm">
              📄 Сформировать первую часть
            </button>
          <% end %>
          
          <%= form_tag pdf_create_generate_path, method: :post, data: { turbo: false }, target: "_blank" do %>
            <%= hidden_field_tag :exam, "math_ege" %>
            <%= hidden_field_tag :part, "full_variant" %>
            <button type="submit" class="w-full px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition font-medium text-sm">
              📚 Сформировать весь вариант
            </button>
          <% end %>
          
          <%# Разделитель %>
          <div class="relative my-2">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-200"></div>
            </div>
            <div class="relative flex justify-center text-xs">
              <span class="px-2 bg-white text-gray-400">или</span>
            </div>
          </div>
          
          <%# Выпадающий список для отдельного задания %>
          <details class="group">
            <summary class="cursor-pointer text-center w-full px-4 py-2.5 bg-gray-50 hover:bg-gray-100 text-gray-600 rounded-lg transition font-medium text-sm flex items-center justify-center gap-2">
              🔢 Сформировать задания по номеру
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="mt-3 p-3 bg-gray-50 rounded-lg">
              <div class="grid grid-cols-5 gap-2">
                <% (1..19).each do |task_number| %>
                  <%= form_tag pdf_create_generate_path, method: :post, data: { turbo: false }, target: "_blank", style: "display: contents" do %>
                    <%= hidden_field_tag :exam, "math_ege" %>
                    <%= hidden_field_tag :part, "single_task" %>
                    <%= hidden_field_tag :task_number, task_number %>
                    <button type="submit" class="px-2 py-1 text-sm bg-white hover:bg-blue-100 text-gray-700 rounded border border-gray-200 transition">
                      <%= task_number %>
                    </button>
                  <% end %>
                <% end %>
              </div>
            </div>
          </details>
        </div>
      </div>
    </div>

    <%# Остальные блоки аналогично... %>
    
  </div>
</div>