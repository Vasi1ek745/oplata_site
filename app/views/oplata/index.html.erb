<% content_for :title, "Oplata" %>

<div class="w-full mt-0 pt-0 px-4 sm:px-0">
  <div class="flex justify-between items-center mb-4">
    <div class="flex items-center gap-3 w-full sm:w-auto justify-between sm:justify-start">
      <h1 class="font-bold text-2xl sm:text-3xl">Платежи</h1>
      
      <div class="flex items-center gap-2">
        <%# Кнопка обновления с анимацией загрузки %>
        <div data-controller="refresh-button">
          <%= link_to refresh_data_oplata_path, 
                method: :get,
                class: "p-2 sm:p-1.5 text-gray-500 hover:text-blue-600 hover:bg-blue-50 rounded-full transition",
                title: "Обновить список",
                data: { 
                  turbo: false,
                  refresh_button_target: "button"
                } do %>
            <svg class="w-5 h-5 refresh-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                 data-refresh-button-target="icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          <% end %>

          <div id="loading-indicator" 
               class="hidden items-center gap-1.5 text-blue-600"
               data-refresh-button-target="indicator">
            <svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            <span class="text-sm font-medium">Обновление...</span>
          </div>
        </div>
        
        <%# Кнопка ручного обновления cron (опционально) %>
        <%= link_to manual_refresh_oplata_path, 
              method: :get,
              class: "p-2 sm:p-1.5 text-gray-500 hover:text-green-600 hover:bg-green-50 rounded-full transition",
              title: "Принудительное обновление (cron)" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        <% end %>
      </div>
    </div>
    
    <div class="flex gap-2">
      <%# Кнопка "Недавно оплаченные" %>
      <%= link_to recently_paid_oplata_path, 
            class: "rounded-md px-3 py-2 bg-gray-500 hover:bg-gray-600 text-white font-medium text-sm flex items-center gap-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Недавно оплаченные
      <% end %>
      
      <%# Кнопка "Новый платёж" %>
      <%= link_to "Новый платёж", new_oplatum_path, 
          class: "rounded-md px-3 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium text-sm" %>
    </div>
  </div>

  <%# Фильтруем только неоплаченные и неотмененные записи %>
  <% unpaid_not_canceled = @oplata.reject { |o| o.pay || o.canceled } %>
  
  <% if unpaid_not_canceled.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <%# Заголовок таблицы - порядок: Дата | Название | Длительность | Способ оплаты | Оплачено | Удалить %>
<div class="hidden sm:grid grid-cols-12 gap-3 px-4 py-2 bg-gray-50 border-b border-gray-200 text-xs font-semibold uppercase tracking-wider text-gray-500">
  <div class="col-span-2">Дата</div>
  <div class="col-span-3">Название</div>
  <div class="col-span-1 text-center">Длит.</div>
  <div class="col-span-4 text-center">Способ оплаты</div>
  <div class="col-span-2 text-right">Действия</div>
</div>
      <div id="oplata-rows" class="divide-y divide-gray-100">
        <%= render partial: "oplata/oplatum_row_shared", collection: unpaid_not_canceled, as: :oplatum %>
      </div>
    </div>
  <% else %>
    <div class="text-center py-8 sm:py-12 bg-white rounded-xl border border-gray-200">
      <svg class="mx-auto h-10 w-10 sm:h-12 sm:w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="mt-3 text-gray-500">Нет активных платежей</p>
      <%= link_to "Создать новый платёж", new_oplatum_path, 
          class: "mt-3 inline-block text-blue-600 hover:text-blue-800 text-sm" %>
    </div>
  <% end %>
</div>

